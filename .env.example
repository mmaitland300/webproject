# Required
NEXT_PUBLIC_SITE_URL=https://your-domain.com
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — shown in footer/contact sidebar; defaults to contact@mmaitland.dev in code
# NEXT_PUBLIC_CONTACT_EMAIL=

# Optional (admin + persistence)
# DATABASE_URL=
# DIRECT_URL=
# AUTH_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# ADMIN_GITHUB_IDS=
#
# Auth.js (NextAuth v5): canonical site URL for OAuth redirects. Must match the origin where you run Next.
# - Local dev: AUTH_URL=http://localhost:3000 (if you only set production URL here, Sign in will redirect to prod)
# - Production: AUTH_URL=https://your-domain.com
# AUTH_URL=
