# Required
NEXT_PUBLIC_SITE_URL=https://your-domain.com
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Prisma (`prisma.config.ts`): both URLs must be set for `npm install` / `prisma generate`
# (postinstall). They do not need to reach a running server for client generation. Use placeholders
# until you configure Neon, then replace with pooled + direct URLs when enabling DB features.
DATABASE_URL=postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder
DIRECT_URL=postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder

# Optional: public URL for the Snake Detector live demo (projects card + case study).
# Must be http(s). When unset, the experiment stays "shipped" and CTAs point to proof + repo only.
# NEXT_PUBLIC_SNAKE_DEMO_URL=

# Optional: shown in footer/contact sidebar; defaults to contact@mmaitland.dev in code
# NEXT_PUBLIC_CONTACT_EMAIL=

# Optional (admin + persistence): set when replacing placeholders above with Neon
# AUTH_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# ADMIN_GITHUB_IDS=
#
# Auth.js (NextAuth v5): canonical site URL for OAuth redirects. Must match the origin where you run Next.
# - Local dev: AUTH_URL=http://localhost:3000 (if you only set production URL here, Sign in will redirect to prod)
# - Production: AUTH_URL=https://your-domain.com
# AUTH_URL=
