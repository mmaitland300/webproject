# Site URL (used for metadata, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Resend (contact form email delivery)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_FROM_EMAIL=contact@mail.yourdomain.com
CONTACT_TO_EMAIL=you@yourdomain.com

# Upstash Redis (contact form rate limiting)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# Phase 3: Database (Neon PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require  (pooled)
# DIRECT_URL=postgresql://user:pass@host/db?sslmode=require    (direct, for Prisma CLI)

# Phase 3: Auth.js
# AUTH_SECRET=generate-with-npx-auth-secret
# AUTH_GITHUB_ID=your-github-oauth-app-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-secret
# ADMIN_GITHUB_IDS=12345678,87654321
